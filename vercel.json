{
  "headers": [
    {
      "source": "/(.*)\\.(lua|luau|txt)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/scripts/api/get-raw/Muscle-Legends.luau",
      "destination": "/warn.html",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/warn.html",
      "permanent": false
    }
  ]
}
